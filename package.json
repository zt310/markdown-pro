{
  "name": "md-viewer-pro",
  "version": "1.0.0",
  "description": "MarkDown Pro — 本地 Markdown 查看器",
  "main": "main.js",
  "scripts": {
    "start": "node_modules/electron/dist/electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable",
    "dist-installer": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.notepro.mdviewer",
    "productName": "MarkDown Pro",
    "directories": {
      "output": "build"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "electronDist": "./node_modules/electron/dist"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.3.0",
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}