{
  "name": "markdown-pro",
  "version": "1.3.0",
  "description": "\u4e00\u4e2a\u672c\u5730 Markdown \u67e5\u770b\u5668 \u2014 \u652f\u6301 CommonMark \u00b7 GFM \u00b7 Mermaid \u00b7 KaTeX \u00b7 \u53cc\u94fe\u7b14\u8bb0",
  "author": "zt310",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zt310/markdown-pro.git"
  },
  "homepage": "https://github.com/zt310/markdown-pro",
  "bugs": {
    "url": "https://github.com/zt310/markdown-pro/issues"
  },
  "keywords": [
    "markdown",
    "editor",
    "viewer",
    "electron",
    "commonmark",
    "gfm",
    "mermaid",
    "katex",
    "wikilinks"
  ],
  "main": "main.js",
  "scripts": {
    "start": "node_modules/electron/dist/electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable",
    "dist-installer": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.zt310.markdown-pro",
    "productName": "MarkDown Pro",
    "directories": {
      "output": "build"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "electronDist": "./node_modules/electron/dist"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.3.0",
    "mermaid": "^11.16.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}